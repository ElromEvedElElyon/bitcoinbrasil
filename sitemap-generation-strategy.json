{
  "sitemapStrategy": {
    "overview": "Comprehensive XML sitemap generation strategy for 1001 pages across 7 languages with optimal SEO structure",
    "objectives": [
      "Ensure complete search engine discoverability",
      "Optimize crawl budget allocation",
      "Provide clear site hierarchy",
      "Support international SEO",
      "Enable efficient content updates",
      "Facilitate fast indexing of new content"
    ]
  },
  "sitemapStructure": {
    "masterSitemap": {
      "filename": "sitemap.xml",
      "purpose": "Main sitemap index pointing to all sub-sitemaps",
      "location": "https://bitcoinbrasil.com/sitemap.xml",
      "content": [
        "Language-specific sitemaps",
        "Category-specific sitemaps",
        "News sitemap",
        "Image sitemap",
        "Video sitemap"
      ]
    },
    "languageSitemaps": {
      "structure": "sitemap-{language}.xml",
      "files": [
        {
          "filename": "sitemap-pt.xml",
          "language": "pt-BR",
          "pages": 200,
          "priority": "highest"
        },
        {
          "filename": "sitemap-en.xml",
          "language": "en-US",
          "pages": 200,
          "priority": "high"
        },
        {
          "filename": "sitemap-es.xml",
