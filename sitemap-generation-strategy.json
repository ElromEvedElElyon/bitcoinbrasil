          "pages": 100,
          "priority": "medium"
        },
        {
          "filename": "sitemap-de.xml",
          "language": "de-DE",
          "pages": 100,
          "priority": "medium"
        },
        {
          "filename": "sitemap-zh.xml",
          "language": "zh-CN",
          "pages": 120,
          "priority": "medium"
        },
        {
          "filename": "sitemap-ja.xml",
          "language": "ja-JP",
          "pages": 130,
          "priority": "medium"
        }
      ]
    },
    "categorySitemaps": {
      "structure": "sitemap-{category}-{language}.xml",
      "files": [
        {
          "filename": "sitemap-ai-trading-pt.xml",
          "category": "AI Trading",
          "language": "pt",
          "pages": 35,
          "updateFrequency": "weekly"
        },
        {
          "filename": "sitemap-crypto-education-pt.xml",
          "category": "Crypto Education",
          "language": "pt",
          "pages": 30,
          "updateFrequency": "weekly"
        },
        {
          "filename": "sitemap-defi-protocols-pt.xml",
          "category": "DeFi Protocols",
          "language": "pt",
          "pages": 20,
          "updateFrequency": "daily"
        },
        {
          "filename": "sitemap-market-intelligence-pt.xml",
          "category": "Market Intelligence",
          "language": "pt",
          "pages": 30,
          "updateFrequency": "daily"
        },
        {
          "filename": "sitemap-news-analysis-pt.xml",
          "category": "News Analysis",
          "language": "pt",
          "pages": 25,
          "updateFrequency": "hourly"
        }
      ]
    },
    "specializedSitemaps": {
      "newsSitemap": {
        "filename": "sitemap-news.xml",
        "purpose": "Google News compliance",
        "content": "Last 3 days of news articles",
        "updateFrequency": "hourly",
        "maxArticles": 1000
      },
      "imageSitemap": {
        "filename": "sitemap-images.xml",
        "purpose": "Image search optimization",
        "content": "All article images, infographics, charts",
